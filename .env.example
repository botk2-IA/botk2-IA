# ── BASE DE DATOS ─────────────────────────────────────────────────
# Railway lo setea automáticamente al agregar el plugin PostgreSQL.
# En local no es necesario (usa SQLite por defecto).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── SEGURIDAD ─────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT. Cambiala en producción.
# Generá una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# ── PANEL ADMIN ───────────────────────────────────────────────────
# SHA-256 de la contraseña del panel /admin
# Generá con: python -c "import hashlib; print(hashlib.sha256(b'tu_pass').hexdigest())"
ADMIN_PASSWORD_HASH=

# ── URL PÚBLICA DE LA APP ─────────────────────────────────────────
# Se usa para armar las URLs de retorno de MercadoPago y Stripe
APP_URL=https://tu-app.railway.app

# ── MERCADOPAGO (Argentina y LATAM) ───────────────────────────────
# Conseguilo en: https://www.mercadopago.com.ar/developers/panel
# Usá el Access Token de PRODUCCIÓN (empieza con APP_USR-)
# o el de SANDBOX (APP_USR-... de prueba) para testear
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ── STRIPE (Internacional) ────────────────────────────────────────
# Conseguilo en: https://dashboard.stripe.com/apikeys
# sk_test_... para pruebas / sk_live_... para producción
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Conseguilo en Stripe → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── WHATSAPP (cuando lo conectes) ────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
